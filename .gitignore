# Environment
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/

# Instance state (never commit)
sol_sniper_state.json
*_state.json
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# macOS launchd (instance-specific)
launchd/*.plist

# Scratch / local
tmp/
scratch/

# Receipt rule engine: rules.py is forker-config (copy from rules.example.py)
receipt-rule-engine/rules.py

# Receipt viewer: live JSONL feeds (forkers populate via their own sync)
receipt-viewer/*.jsonl
!receipt-viewer/code-writing-demo.jsonl
receipt-viewer/data/*.json
!receipt-viewer/data/*.sample
