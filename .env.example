# iBitLabs — Environment Variable Template
# Copy to `.env` and fill in. Never commit `.env`.
# .env is gitignored in .gitignore at repo root.

# ── Coinbase Advanced Trade API (futures-enabled account) ──
# Generate at: https://www.coinbase.com/settings/api
# Required permissions: View, Trade (futures). Do not enable Transfer.
CB_API_KEY=organizations/your-org-id/apiKeys/your-key-id
CB_API_SECRET="-----BEGIN EC PRIVATE KEY-----
YOUR_COINBASE_EC_PRIVATE_KEY_PEM_GOES_HERE_MULTI_LINE
-----END EC PRIVATE KEY-----"

# ── Strategy overrides (optional) ──
# These override config defaults in sol_sniper_config.py. See the disclaimer
# in README.md about not forking these verbatim.
# SNIPER_TP_PCT=999.0             # disabled = trailing-only exit
# SNIPER_STOCH_RSI_LONG=0.10
# SNIPER_STOCH_RSI_SHORT=0.90

# ── Shadow rule B log path (optional) ──
# Defaults to ./logs/shadow_12h_rule.jsonl relative to cwd
# SHADOW_12H_LOG=./logs/shadow_12h_rule.jsonl

# ── Auto-post Telegram channel (optional) ──
# Leave blank to disable auto-post. If enabled, the bot posts every trade
# entry / exit / PnL within seconds of exchange execution.
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyz
# TELEGRAM_CHAT_ID=@your_channel_or_-100xxxxxxxxxx

# ── Instance state file path (optional) ──
# The bot writes position state here so it survives restarts. Instance-specific.
# SNIPER_STATE_FILE=./sol_sniper_state.json

# ── Notification fallback (optional) ──
# Used for alerts when the bot detects DB ↔ exchange drift.
# NTFY_TOPIC=your-unique-topic-string
