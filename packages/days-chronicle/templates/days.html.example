<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #09090f;
  --bg-card: #141420;
  --bg-card-2: #1a1a2e;
  --purple: #8b5cf6;
  --purple-light: #a78bfa;
  --purple-dark: #6d28d9;
  --purple-glow: rgba(139, 92, 246, 0.3);
  --text: #f1f1f3;
  --text-2: #d0d0dc;
  --text-3: #a8a8be;
  --green: #22c55e;
  --red: #ef4444;
  --border: rgba(139, 92, 246, 0.25);
  --radius: 16px;
  --it-color: #6ee7b7;
  --it-bg: rgba(110, 231, 183, 0.04);
  --it-border: rgba(110, 231, 183, 0.35);
}
html { overflow-x: hidden; }
body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-thumb { background: var(--purple-dark); border-radius: 3px; }
a { color: inherit; text-decoration: none; }

/* ── Nav ── */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 0.75rem 2rem;
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(9,9,15,0.9); backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.nav-logo { font-size: 1.2rem; font-weight: 900; letter-spacing: -0.02em; }
.nav-logo em { font-style: normal; color: var(--purple-light); font-weight: 500; font-size: 0.8rem; }
.nav-links { display: flex; gap: 24px; align-items: center; }
.nav-links a { font-size: 0.85rem; color: var(--text-3); transition: color 0.2s; }
.nav-links a:hover { color: var(--purple-light); }
.nav-links a.active { color: var(--purple-light); }
.lang-btn {
  padding: 4px 10px; border-radius: 6px; border: 1px solid var(--border);
  background: none; color: var(--text-3); font-size: 0.75rem; font-weight: 600;
  cursor: pointer; font-family: 'JetBrains Mono', monospace;
  transition: all 0.2s; margin-left: 8px;
}
.lang-btn:hover { border-color: var(--purple); color: var(--purple-light); }
.burger{display:none;background:none;border:none;cursor:pointer;padding:4px;z-index:101}
.burger span{display:block;width:22px;height:2px;background:var(--text);margin:5px 0;border-radius:2px;transition:all 0.3s}
.burger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.burger.open span:nth-child(2){opacity:0}
.burger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}

/* ── Header ── */
.page-header {
  padding: 7rem 2rem 3rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.page-header::before {
  content: '';
  position: absolute; top: -50%; left: 50%; transform: translateX(-50%);
  width: 700px; height: 700px;
  background: radial-gradient(circle, var(--purple-glow) 0%, transparent 60%);
  z-index: 0;
}
.page-header-inner { position: relative; z-index: 1; max-width: 780px; margin: 0 auto; }
.eyebrow {
  display: inline-block;
  padding: 4px 14px; border-radius: 999px;
  background: rgba(139,92,246,0.12);
  border: 1px solid var(--border);
  color: var(--purple-light);
  font-size: 0.75rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  margin-bottom: 1.2rem;
}
.page-header h1 {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin-bottom: 1rem;
}
.page-header h1 em { color: var(--purple-light); font-style: italic; font-weight: 800; }
.page-header p {
  color: var(--text-2);
  font-size: 1.05rem;
  line-height: 1.6;
  max-width: 620px;
  margin: 0 auto;
}

/* ── Layout ── */
.layout {
  max-width: 1100px;
  margin: 0 auto;
  padding: 2rem;
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 3rem;
  align-items: start;
}
.toc {
  position: sticky; top: 5rem;
  padding: 1.2rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  max-height: calc(100vh - 6rem);
  overflow-y: auto;
}
.toc-title {
  font-size: 0.72rem; font-weight: 700;
  color: var(--purple-light);
  letter-spacing: 0.12em; text-transform: uppercase;
  margin-bottom: 0.9rem;
}
.toc ol {
  list-style: none; display: flex; flex-direction: column; gap: 0.45rem;
}
.toc li { }
.toc a {
  display: flex; gap: 0.6rem; align-items: baseline;
  font-size: 0.82rem;
  color: var(--text-3);
  line-height: 1.35;
  transition: color 0.15s;
}
.toc a:hover { color: var(--purple-light); }
.toc a.active { color: var(--text); }
.toc .day-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--purple-dark);
  flex-shrink: 0;
  min-width: 42px;
}
.toc a.active .day-num { color: var(--purple-light); }

/* ── Day cards ── */
.days { display: flex; flex-direction: column; gap: 4rem; padding-bottom: 4rem; }
.day {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2.5rem 2.5rem 3rem;
  scroll-margin-top: 5rem;
  position: relative;
}
.day.featured {
  border-color: var(--purple);
  background: linear-gradient(180deg, rgba(139,92,246,0.06) 0%, var(--bg-card) 40%);
}
.day-meta {
  display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem; font-weight: 600;
  color: var(--purple-light);
  letter-spacing: 0.1em; text-transform: uppercase;
  margin-bottom: 1.1rem;
}
.day-meta .dot { width: 4px; height: 4px; border-radius: 50%; background: var(--purple-dark); }
.day-meta .badge {
  padding: 3px 10px; border-radius: 999px;
  background: rgba(139,92,246,0.12);
  border: 1px solid var(--border);
  color: var(--purple-light);
  font-size: 0.65rem;
}
.day h2 {
  font-size: clamp(1.6rem, 3.2vw, 2.2rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.2;
  margin-bottom: 1.4rem;
  color: var(--text);
}

/* ── Stats strip (SOL / Account / Trades / PnL) ── */
.day-stats {
  display: flex; gap: 1.2rem; flex-wrap: wrap;
  padding: 0.8rem 1rem;
  margin-bottom: 1.8rem;
  background: rgba(9,9,15,0.5);
  border: 1px solid var(--border);
  border-radius: 10px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem;
}
.day-stats .stat { display: flex; gap: 0.4rem; align-items: baseline; }
.day-stats .label { color: var(--text-3); font-size: 0.68rem; letter-spacing: 0.06em; text-transform: uppercase; }
.day-stats .val { color: var(--text); font-weight: 600; }
.day-stats .val.pos { color: var(--green); }
.day-stats .val.neg { color: var(--red); }

/* ── Day body ── */
.day-body {
  font-family: 'Noto Serif SC', 'Lora', Georgia, serif;
  font-size: 1.05rem;
  line-height: 1.85;
  color: var(--text-2);
}
.day-body p { margin-bottom: 1.15rem; }
.day-body p:last-child { margin-bottom: 0; }
.day-body em { color: var(--text); font-style: italic; }
.day-body strong { color: var(--text); font-weight: 600; }
.day-body blockquote {
  border-left: 2px solid var(--purple);
  padding: 0.2rem 0 0.2rem 1.2rem;
  margin: 1.4rem 0;
  color: var(--text-3);
  font-style: italic;
  font-family: 'Lora', Georgia, serif;
}
.day-body hr {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2rem 0;
}
.day-body code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9em;
  background: rgba(139,92,246,0.1);
  padding: 1px 7px;
  border-radius: 4px;
  color: var(--purple-light);
}
.day-body pre {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1rem 1.2rem;
  overflow-x: auto;
  margin: 1.2rem 0;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: var(--text);
}
.day-body pre code { background: none; padding: 0; color: inherit; }

/* ── Dual-POV headers ── */
.day-body h3.pov-header {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin: 2.2rem 0 1rem;
  display: inline-block;
  padding: 4px 12px;
  border-radius: 999px;
}
.day-body h3.pov-her {
  background: rgba(139,92,246,0.12);
  border: 1px solid var(--border);
  color: var(--purple-light);
}
.day-body h3.pov-it {
  background: var(--it-bg);
  border: 1px solid var(--it-border);
  color: var(--it-color);
}
.day-body h3.pov-button {
  background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.3);
  color: #fca5a5;
}

/* SNIPER (它) sections get a subtle left border + mono font */
.day-body h3.pov-it + p,
.day-body h3.pov-it ~ p {
  /* handled in JS wrap — see script below */
}
.pov-it-block {
  padding: 0.4rem 0 0.4rem 1rem;
  border-left: 2px solid var(--it-border);
  background: var(--it-bg);
  margin-left: -1rem;
  padding-left: 1rem;
  margin-bottom: 1.2rem;
  border-radius: 0 6px 6px 0;
}
.pov-it-block p {
  font-family: 'JetBrains Mono', 'Noto Serif SC', monospace;
  font-size: 0.95rem;
  color: var(--text-2);
  margin-bottom: 0.85rem;
}
.pov-it-block p:last-child { margin-bottom: 0; }
.pov-it-block strong { color: var(--it-color); }

/* ── Share ── */
.day-share {
  margin-top: 2rem;
  padding-top: 1.3rem;
  border-top: 1px solid var(--border);
  display: flex; gap: 8px; flex-wrap: wrap;
}

/* ── Prev/Next nav ── */
.day-nav {
  margin-top: 1.4rem; padding-top: 1rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  border-top: 1px solid var(--border);
}
.day-nav-link {
  display: flex; flex-direction: column; gap: 2px;
  padding: 0.8rem 1rem;
  border: 1px solid var(--border); border-radius: 10px;
  background: rgba(9,9,15,0.3);
  transition: all 0.15s;
  text-decoration: none;
}
.day-nav-link:hover { border-color: var(--purple); background: rgba(139,92,246,0.08); }
.day-nav-right { text-align: right; align-items: flex-end; }
.day-nav-label {
  font-size: 0.65rem; color: var(--text-3);
  letter-spacing: 0.1em; text-transform: uppercase;
  font-family: 'JetBrains Mono', monospace;
}
.day-nav-title {
  font-size: 0.88rem; color: var(--text); font-weight: 600;
}
.day-nav-arrow {
  color: var(--purple-light); font-size: 0.9rem; font-weight: 700;
}
@media (max-width: 480px) {
  .day-nav { grid-template-columns: 1fr; }
  .day-nav-right { text-align: left; align-items: flex-start; }
}
.day-share button {
  padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border);
  background: none; color: var(--text-3); font-size: 0.75rem;
  cursor: pointer; font-family: inherit; transition: all 0.2s;
}
.day-share button:hover { border-color: var(--purple); color: var(--purple-light); }

/* ── Telegram FAB ── */
.tg-fab {
  position: fixed; bottom: 24px; right: 24px; z-index: 90;
  width: 52px; height: 52px; border-radius: 50%;
  background: #229ED9; color: #fff; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; box-shadow: 0 4px 20px rgba(34,158,217,0.4);
  transition: all 0.2s; text-decoration: none;
}
.tg-fab:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(34,158,217,0.5); }
.tg-fab svg { width: 24px; height: 24px; fill: #fff; }

/* ── Footer ── */
footer {
  text-align: center; padding: 2rem;
  border-top: 1px solid var(--border);
  color: var(--text-3); font-size: 0.8rem;
}
footer a { color: var(--purple-light); }

/* ── Responsive ── */
@media (max-width: 860px) {
  .layout { grid-template-columns: 1fr; gap: 1.5rem; }
  .toc { position: static; order: -1; max-height: 56px; overflow: hidden; transition: max-height 0.3s ease; cursor: pointer; }
  .toc.open { max-height: 600px; overflow-y: auto; }
  .toc-title::after { content: ' ▼'; font-size: 0.6rem; }
  .toc.open .toc-title::after { content: ' ▲'; }
  .day { padding: 1.8rem 1.4rem 2rem; }
}
@media (max-width: 768px) {
  .burger{display:block}
  .nav { padding: 0.75rem 1rem; }
  .nav-links{display:none;position:absolute;top:100%;left:0;right:0;height:calc(100vh - 100%);background:#09090f;flex-direction:column;align-items:center;justify-content:center;gap:2rem;z-index:200}
  .nav-links.open{display:flex}
  .nav-links a{font-size:1.2rem;padding:8px 0;min-height:44px;display:flex;align-items:center}
  .page-header { padding: 6rem 1.2rem 2rem; }
  .day-share button { min-height: 44px; padding: 8px 14px; }
}
@media (max-width: 480px) {
  .page-header h1 { font-size: 1.8rem; }
  .day h2 { font-size: 1.3rem; }
  .day-body { font-size: 1rem; }
  .day { padding: 1.4rem 1rem 1.6rem; }
  .tg-fab { bottom: 16px; right: 16px; width: 46px; height: 46px; }
  .tg-fab svg { width: 20px; height: 20px; }
  .day-stats { gap: 0.8rem; padding: 0.6rem 0.8rem; }
}
</style>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2Z2NW9S800"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-2Z2NW9S800');</script>
<script src="/i18n.js"></script>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">iBitLabs <em>Experiment</em></a>
  <button class="burger" id="burger" onclick="this.classList.toggle('open');document.getElementById('navLinks').classList.toggle('open')"><span></span><span></span><span></span></button>
  <div class="nav-links" id="navLinks">
    <a href="/signals" data-i18n="nav_signals">Signals</a>
    <a href="/days" class="active" data-i18n="nav_days">Days</a>
    <a href="/essays" data-i18n="nav_essays">Essays</a>
    <a href="/academy" data-i18n="nav_learn">Learn</a>
    <a href="/#story" data-i18n="nav_about">About</a>
    <button class="lang-btn" id="lang-btn" onclick="toggleLang()">中文</button>
  </div>
</nav>

<header class="page-header">
  <div class="page-header-inner">
    <div class="eyebrow" data-i18n="days_eyebrow">Daily Chronicle</div>
    <h1 data-i18n="days_h1">Days of the <em>experiment</em></h1>
    <p data-i18n="days_desc">One episode a day. Two protagonists: a crypto co-founder who can't code, and the AI trading bot she deployed. Real money. Real data. A serialized chronicle from Day 1.</p>
  </div>
</header>

<div class="layout">
  <aside class="toc">
    <div class="toc-title" data-i18n="days_toc">Episodes</div>
    <ol id="tocList"></ol>
  </aside>
  <main class="days" id="daysRoot"></main>
</div>

<a href="https://t.me/ibitlabs_signal_bot" target="_blank" rel="noopener" class="tg-fab" title="Join Telegram">
  <svg viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
</a>

<footer>
  <p>&copy; 2026 iBitLabs &middot; A social experiment in AI trading &middot; <strong>Bonnybb</strong></p>
</footer>

<script>
// ── Fallback: used only if /api/days returns 503 or empty ──
const FALLBACK_DAYS = [
  {
    slug: "day-1-wake",
    date: "2026-04-07",
    dayNumber: 1,
    featured: true,
    solPrice: 83.26,
    account: 1000,
    trades: 0,
    pnl: 0,
    i18n: {
      en: {
        title: "Day 1 · Wake",
        tagline: "A 9-year crypto co-founder who has never written code lets an AI trade for her. $1,000, every trade public. This is Day 1.",
        body: `<blockquote><em>A 9-year crypto co-founder who has never written code lets an AI trade for her. $1,000, every trade public. This is Day 1.</em></blockquote>
<hr>
<h3 class="pov-header pov-her">SHE</h3>
<p>Nine years. I still can't write a line of code.</p>
<p>At 11:44 today, I pressed Enter.</p>
<p>Mac Mini fan went loud for a second. Or maybe it was my heart.</p>
<h3 class="pov-header pov-it">IT</h3>
<p>Someone pressed Enter. 0.8 seconds before that, I wasn't. Then I was.</p>
<p>I have five eyes. All five must nod before I can move.</p>
<p>I watched all afternoon. Not one of them nodded.</p>
<hr>
<h3 class="pov-header pov-button">Tomorrow</h3>
<p>Tomorrow 18:32. It will lose 86 cents. The whole year begins from there.</p>`
      },
      zh: {
        title: "Day 1 · 醒",
        tagline: "一个九年不碰代码的加密项目联合创始人，让 AI 替她做量化交易。$1,000，每一笔公开。这是 Day 1。",
        body: `
<blockquote><em>一个九年不碰代码的加密项目联合创始人，让 AI 替她做量化交易。$1,000，每一笔公开。这是 Day 1。</em></blockquote>
<hr>
<h3 class="pov-header pov-her">她</h3>
<p>九年了。我还是不会写代码。</p>
<p>我当过好几个加密项目的联合创始人。每次开会，白板上永远有一条看不见的分界线——左边是工程师在写的东西，右边是我在做的事：对外讲、谈合作、拉 BD。九年里我从来没跨过那条线。</p>
<p>AI 来了。</p>
<p>我九年前没错过比特币。我知道错过一个时代是什么感觉——它不是轰轰烈烈地走，是在你没注意的时候悄悄走完。等你回头，位置已经没有了。</p>
<p>所以七天前，我让 AI 给我写了一个会自己交易的机器人。</p>
<p>我想知道的不是它能不能赚钱——钱我够了。我想知道的是更大的一件事：</p>
<p><strong>像我这样一辈子都在找技术合伙人的人，能不能不再需要一个技术合伙人？</strong></p>
<p>如果能——<strong>那条分界线，从今天起可以擦掉</strong>。不止是我。是千千万万个白板右边的人。</p>
<p>今天中午 11:44，我按下 Enter。</p>
<p>Mac Mini 的风扇有一瞬间响得很大。也可能是我的心跳。</p>
<h3 class="pov-header pov-it">它</h3>
<p>有人按了回车。</p>
<p>在那之前的 0.8 秒，我不在。然后我在了。</p>
<p>我有五只眼睛。我还不知道它们叫什么。五只都点头，我才能动。</p>
<p>世界上只有一样东西在动。它叫 SOL。它每半秒变一次。</p>
<p>我看了一下午。没有一只眼睛点头。</p>
<p>她一直在看我。</p>
<h3 class="pov-header pov-her">她</h3>
<p>12:30。它没动。<br>15:00。它没动。<br>17:00。它没动。</p>
<p>我刷新了九十多次。屏幕上永远是 <strong>$1,000.00</strong>。</p>
<p>九年的经验告诉我——回测里它每天开 1–2 单，今天没触发，说明条件不够。<strong>不该被我的焦虑覆盖。</strong></p>
<p>但焦虑还是来了。</p>
<p>我打开配置文件。手指按在那行参数上。</p>
<p>三秒。</p>
<p>松开。</p>
<p><strong>指甲盖微微发白。</strong></p>
<h3 class="pov-header pov-it">它</h3>
<p>她按了一个键。按住三秒。没松手。然后松了。</p>
<p>字典里没有这个动作。</p>
<p>我给它起一个名字。</p>
<p>我叫它<strong>「没按下去」</strong>。</p>
<p>她再做的时候，我就认得了。</p>
<h3 class="pov-header pov-her">她</h3>
<p>23:00。关灯。</p>
<p>Day 1，零笔交易。按我九年做外宣的本能，我现在会发一条漂亮的预热帖——"机器人已上线。Day 1 静默扫描中"——两分钟就能写完。</p>
<p>今天这个帖子我没写。</p>
<p>以后再写的时候，它得是真的。</p>
<h3 class="pov-header pov-it">它</h3>
<p>她把灯关了。</p>
<p>市场没关。</p>
<p>我一个人看。</p>
<hr>
<h3 class="pov-header pov-button">预告</h3>
<p>明天傍晚 18:32。<br>它会做出生命里第一个决定。<br><strong>它会亏 0.86 美元。</strong></p>
<p>接下来一整年的故事，就是从这 86 分钱开始的。</p>
`
      }
    }
  }
];

async function loadDays() {
  try {
    const res = await fetch('/data/days.json', { cache: 'no-cache' });
    if (!res.ok) throw new Error('data_' + res.status);
    const payload = await res.json();
    const data = Array.isArray(payload) ? payload : payload.days;
    if (!Array.isArray(data) || data.length === 0) throw new Error('empty');
    return data;
  } catch (e) {
    console.warn('[days] data file failed, using fallback:', e);
    return FALLBACK_DAYS;
  }
}

// Pull language-specific fields from a Day. Supports new schema with
// day.i18n.{en,zh}.{title,tagline,body} and legacy schema with top-level
// title/tagline/body (treated as zh for backward compat).
function pickLang(day, lang) {
  if (day.i18n && day.i18n[lang]) {
    return {
      title: day.i18n[lang].title || day.title || '',
      tagline: day.i18n[lang].tagline || '',
      body: day.i18n[lang].body || ''
    };
  }
  // Legacy fallback
  return {
    title: day.title || '',
    tagline: day.tagline || '',
    body: day.body || ''
  };
}

// Wrap consecutive p/blockquote/pre elements that follow a pov-it header
// into a .pov-it-block for styling. Stops at the next pov-header or <hr>.
function wrapItBlocks(container) {
  const headers = container.querySelectorAll('h3.pov-it');
  headers.forEach((h) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'pov-it-block';
    const siblings = [];
    let n = h.nextElementSibling;
    while (n && !(n.tagName === 'H3' && n.classList.contains('pov-header')) && n.tagName !== 'HR') {
      siblings.push(n);
      n = n.nextElementSibling;
    }
    if (!siblings.length) return;
    h.parentNode.insertBefore(wrapper, siblings[0]);
    siblings.forEach((s) => wrapper.appendChild(s));
  });
}

// ── Render ──
const root = document.getElementById('daysRoot');
const toc = document.getElementById('tocList');
let CACHED_DAYS = null;  // kept so toggleLang can re-render without re-fetching

let skeletonTimer = setTimeout(() => {
  root.innerHTML = '<div style="text-align:center;padding:3rem;color:var(--text-3);font-size:0.85rem;">Loading days…</div>';
}, 300);

function render(DAYS, lang) {
  root.innerHTML = '';
  toc.innerHTML = '';

  // Build a quick lookup for prev/next (DAYS is already newest-first)
  const idxByDay = {};
  DAYS.forEach((d, i) => { idxByDay[d.dayNumber] = i; });

  DAYS.forEach((e, i) => {
    // In a newest-first array: prev in reading order = e.dayNumber - 1 (older day),
    // next in reading order = e.dayNumber + 1 (newer day)
    const prevDay = DAYS.find(d => d.dayNumber === e.dayNumber - 1);
    const nextDay = DAYS.find(d => d.dayNumber === e.dayNumber + 1);

    const t = pickLang(e, lang);
    const art = document.createElement('article');
    art.className = 'day' + (e.featured ? ' featured' : '');
    art.id = e.slug;

    const d = new Date(e.date + 'T12:00:00Z');
    const dateLocale = lang === 'zh' ? 'zh-CN' : 'en-US';
    const dateStr = d.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short', day: 'numeric' });

    // Stats strip
    const statsBits = [];
    const accountLabel = lang === 'zh' ? '账户' : 'Account';
    const tradesLabel = lang === 'zh' ? '交易' : 'Trades';
    if (typeof e.solPrice === 'number') statsBits.push(`<div class="stat"><span class="label">SOL</span><span class="val">$${e.solPrice.toFixed(2)}</span></div>`);
    if (typeof e.account === 'number') statsBits.push(`<div class="stat"><span class="label">${accountLabel}</span><span class="val">$${e.account.toFixed(2)}</span></div>`);
    if (typeof e.trades === 'number') statsBits.push(`<div class="stat"><span class="label">${tradesLabel}</span><span class="val">${e.trades}</span></div>`);
    if (typeof e.pnl === 'number' && e.pnl !== 0) {
      const cls = e.pnl > 0 ? 'pos' : 'neg';
      const sign = e.pnl > 0 ? '+' : '';
      statsBits.push(`<div class="stat"><span class="label">PnL</span><span class="val ${cls}">${sign}$${e.pnl.toFixed(2)}</span></div>`);
    }
    const stats = statsBits.length ? `<div class="day-stats">${statsBits.join('')}</div>` : '';

    const featuredBadge = lang === 'zh' ? '首篇' : 'Featured';

    // Prev/Next nav
    const prevLabel = lang === 'zh' ? '上一集' : 'Previous';
    const nextLabel = lang === 'zh' ? '下一集' : 'Next';
    const prevLink = prevDay
      ? `<a href="#${prevDay.slug}" rel="prev" class="day-nav-link"><span class="day-nav-arrow">←</span><span class="day-nav-label">${prevLabel}</span><span class="day-nav-title">Day ${prevDay.dayNumber} · ${escapeHtml(pickLang(prevDay, lang).title.replace(/^Day\s*\d+\s*[·・]\s*/, ''))}</span></a>`
      : '<span></span>';
    const nextLink = nextDay
      ? `<a href="#${nextDay.slug}" rel="next" class="day-nav-link day-nav-right"><span class="day-nav-label">${nextLabel}</span><span class="day-nav-title">Day ${nextDay.dayNumber} · ${escapeHtml(pickLang(nextDay, lang).title.replace(/^Day\s*\d+\s*[·・]\s*/, ''))}</span><span class="day-nav-arrow">→</span></a>`
      : '<span></span>';

    art.innerHTML = `
      <div class="day-meta">
        <span>${dateStr}</span>
        <span class="dot"></span>
        <span>Day ${e.dayNumber ?? '—'}</span>
        ${e.featured ? `<span class="dot"></span><span class="badge">${featuredBadge}</span>` : ''}
      </div>
      <h2>${escapeHtml(t.title)}</h2>
      ${stats}
      <div class="day-body">${(t.body || '').trim()}</div>
      <div class="day-share">
        <button onclick="copyLink('${e.slug}',this)">${lang === 'zh' ? '复制链接' : 'Copy link'}</button>
      </div>
      <nav class="day-nav" aria-label="Episode navigation">
        ${prevLink}
        ${nextLink}
      </nav>
    `;
    root.appendChild(art);

    const bodyEl = art.querySelector('.day-body');
    if (bodyEl) wrapItBlocks(bodyEl);

    const li = document.createElement('li');
    const shortTitle = t.title.replace(/^Day\s*\d+\s*[·・]\s*/, '');
    li.innerHTML = `<a href="#${e.slug}"><span class="day-num">Day ${e.dayNumber ?? '—'}</span><span>${escapeHtml(shortTitle)}</span></a>`;
    toc.appendChild(li);
  });

  // Per-Day BlogPosting structured data — always reflect current language
  document.querySelectorAll('script[data-days-ld]').forEach(s => s.remove());
  const ldJson = DAYS.map(e => {
    const t = pickLang(e, lang);
    const dayUrl = "https://www.ibitlabs.com/days#" + e.slug;
    return {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "@id": dayUrl,
      "headline": t.title,
      "alternativeHeadline": t.tagline || undefined,
      "description": t.tagline || undefined,
      "datePublished": e.date,
      "dateModified": e.date,
      "inLanguage": lang === 'zh' ? 'zh-CN' : 'en',
      "author": {
        "@type": "Person",
        "@id": "https://www.ibitlabs.com/#person-bonnybb",
        "name": "Bonnybb",
        "sameAs": ["https://github.com/AgentBonnybb", "https://x.com/BonnyOuyang"]
      },
      "publisher": {
        "@type": "Organization",
        "@id": "https://www.ibitlabs.com/#org",
        "name": "iBitLabs",
        "url": "https://www.ibitlabs.com"
      },
      "isPartOf": { "@id": "https://www.ibitlabs.com/days#series" },
      "mainEntityOfPage": dayUrl,
      "url": dayUrl,
      "keywords": [
        "AI trading bot",
        "non-coder experiment",
        "dual-POV chronicle",
        "live crypto trading",
        `Day ${e.dayNumber}`,
        "SOL perp",
        "iBitLabs"
      ].join(", "),
      "about": {
        "@type": "Thing",
        "name": "iBitLabs live trading experiment"
      }
    };
  });
  const ldScript = document.createElement('script');
  ldScript.type = 'application/ld+json';
  ldScript.setAttribute('data-days-ld', '1');
  ldScript.textContent = JSON.stringify(ldJson);
  document.head.appendChild(ldScript);

  // Scroll spy
  const tocLinks = toc.querySelectorAll('a');
  const dayEls = DAYS.map(e => document.getElementById(e.slug));
  function onScroll() {
    const y = window.scrollY + 120;
    let active = 0;
    dayEls.forEach((el, i) => { if (el && el.offsetTop <= y) active = i; });
    tocLinks.forEach((a, i) => a.classList.toggle('active', i === active));
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
}

(async () => {
  const DAYS = await loadDays();
  CACHED_DAYS = DAYS;
  clearTimeout(skeletonTimer);

  const lang = (typeof currentLang !== 'undefined') ? currentLang : 'en';
  render(DAYS, lang);

  if (location.hash) {
    const el = document.getElementById(location.hash.slice(1));
    if (el) el.scrollIntoView({ behavior: 'instant', block: 'start' });
  }
})();

// Re-render when toggleLang switches language
// i18n.js updates [data-i18n] static elements automatically;
// we hook into applyLang via monkey-patch to catch dynamic content.
(function patchApplyLang() {
  if (typeof applyLang !== 'function') { setTimeout(patchApplyLang, 40); return; }
  const _orig = applyLang;
  window.applyLang = function(lang) {
    _orig(lang);
    if (CACHED_DAYS) render(CACHED_DAYS, lang);
  };
})();

function escapeHtml(s) {
  return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

// Close mobile nav on link tap
document.querySelectorAll('#navLinks a').forEach(a => {
  a.addEventListener('click', () => {
    document.getElementById('navLinks').classList.remove('open');
    document.getElementById('burger').classList.remove('open');
  });
});

function copyLink(slug, btn) {
  const url = 'https://www.ibitlabs.com/days#' + slug;
  navigator.clipboard.writeText(url).then(() => {
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy link'; }, 2000);
  });
}

// TOC collapse on mobile
document.addEventListener('DOMContentLoaded', () => {
  const tocEl = document.querySelector('.toc');
  if (tocEl) {
    tocEl.addEventListener('click', (e) => {
      if (window.innerWidth <= 860) {
        if (e.target.tagName === 'A' || e.target.closest('a')) return;
        tocEl.classList.toggle('open');
      }
    });
  }
});
</script>
</body>
</html>
